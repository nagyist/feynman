{
  "name": "feynman",
  "version": "0.1.0",
  "private": true,
  "description": "Research-first agent built on pi-coding-agent",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "pi-package",
    "research-agent",
    "literature-review",
    "experiments"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "@companion-ai/alpha-hub": "^0.1.0",
    "@mariozechner/pi-ai": "^0.56.1",
    "@mariozechner/pi-coding-agent": "^0.56.1",
    "@sinclair/typebox": "^0.34.41",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
